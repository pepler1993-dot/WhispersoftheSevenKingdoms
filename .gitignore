.claw/
__pycache__/
*.pyc

# Runtime data
data/output/youtube/*/video.mp4
data/output/youtube/*/video.loop.mp4
data/work/publish/reports/*.json
!data/work/publish/reports/.gitkeep

# SQLite databases & WAL files
services/sync/data/*.db
services/sync/data/*.db-shm
services/sync/data/*.db-wal
services/sync/data/test/

# Upload artifacts (keep structure, ignore large files)
data/upload/done/*/whispers-*-looped*.mp3
data/upload/songs/*.mp3
data/upload/songs/*.wav
!data/upload/songs/.gitkeep

# Processed audio (generated by pipeline)
data/upload/songs/*-processed.mp3
data/upload/songs/*-looped.mp3
data/upload/songs/*-looped-processed.mp3

# OAuth Secrets
client_secret*.json
.youtube_token.json
data/secrets/
token.json

# Environment & Keys
.env
*.pem
*.key

# Virtual Environment
.venv/
data/agent_sync.db
