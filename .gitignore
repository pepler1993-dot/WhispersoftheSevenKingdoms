.claw/
__pycache__/
*.pyc

# Runtime reports
work/publish/reports/*.json
!work/publish/reports/.gitkeep

# SQLite databases & WAL files
agent-sync-service/data/*.db
agent-sync-service/data/*.db-shm
agent-sync-service/data/*.db-wal
agent-sync-service/data/test/

# Output files (generated, large binaries)
output/youtube/*/video.mp4
output/youtube/*/video.loop.mp4

# Processed audio (generated by pipeline)
upload/songs/*-processed.mp3
upload/songs/*-looped.mp3
upload/songs/*-looped-processed.mp3

# OAuth Secrets
client_secret*.json
.youtube_token.json
